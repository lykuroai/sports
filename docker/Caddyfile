# サブドメイン → 各 app コンテナへリバースプロキシ。
# 本番・開発とも同一構成。TLS は docker/certs のワイルドカード実証明書
# （*.lykuro.ai, 公的CA発行）を使う。ACME 自動取得はしない。
#   - fullchain.pem        … 証明書チェーン
#   - privkey.nopass.pem   … 復号済み秘密鍵（Caddy は暗号化鍵を読めないため
#                            key_pass.txt のパスフレーズで openssl pkey 復号したもの）
#
# DNS: 各サブドメインを当サーバ（本番）/ 127.0.0.1（開発機の /etc/hosts）へ向ける。
# 証明書が無い環境で動かす場合は各ブロックの `import realtls` を `tls internal` に
# 戻せば Caddy 内部CAの自己署名で動作する。

(realtls) {
	tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.nopass.pem
}

# 統合サイト化により公開は web（統合サイト）と admin（管理）の2本のみ。
# account/facility/golf/outdoor/running は web へ集約・撤去済み。
spotomo.lykuro.ai {
	import realtls
	reverse_proxy web:3000
}

admin-spotomo.lykuro.ai {
	import realtls
	reverse_proxy admin:3000
}
