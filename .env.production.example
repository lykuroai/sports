# docker compose 用の本番環境変数。`.env.production` にコピーして設定。
# 全 app コンテナへ env_file で渡す（各 app は必要な変数だけ参照）。

# --- Supabase（ホスティング or セルフホスト）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバー専用。web(統合サイト・取り込みバッチ含む)/account/golf/running/outdoor/facility/admin が利用
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- ドメイン / SSO ---
NEXT_PUBLIC_SITE_URL=https://spotomo.lykuro.ai
NEXT_PUBLIC_ACCOUNT_URL=https://account-spotomo.lykuro.ai
NEXT_PUBLIC_FACILITY_URL=https://facility-spotomo.lykuro.ai
# サブドメイン間で session Cookie を共有（共通 user_id の SSO）
NEXT_PUBLIC_COOKIE_DOMAIN=.lykuro.ai

# --- メール通知（Amazon SES）---
# AWS 認証情報（SES 送信権限）。EC2 ならインスタンスロールでも可（その場合キーは空でよい）。
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAIL_PROVIDER=ses
FROM_ADDRESS=no-reply@lykuro.ai
FROM_NAME=SpoTom

# --- 携帯番号認証（Twilio Verify, account のみ）---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- CAPTCHA（Cloudflare Turnstile, account の認証画面）---
# Cloudflare ダッシュボードで Turnstile ウィジェットを作成して取得。
# SITE_KEY はクライアント公開、SECRET_KEY はサーバー検証用（漏らさない）。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Stripe（facility のみ）---
STRIPE_SECRET_KEY=rk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- LINE ログイン（account のみ）---
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- 楽天GORA（golf のみ。ゴルフ場検索・プラン検索／予約は楽天GORAへ送客）---
# 楽天ウェブサービス（https://webservice.rakuten.co.jp/）でアプリ登録して取得。
# サーバー側のみで使用しフロントには公開しない。未設定ならゴルフ場検索は無効化。
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=
RAKUTEN_GORA_API_BASE_URL=https://openapi.rakuten.co.jp/engine/api
# 楽天ゲートウェイは「アプリに登録した URL（リファラ）」必須。サーバー fetch が送る
# Referer の値（未設定なら NEXT_PUBLIC_GOLF_URL→既定の golf 本番ドメイン）。
RAKUTEN_GORA_REFERER=https://golf-spotomo.lykuro.ai
# affiliateId を使うと登録リファラ必須になり 403 になりやすい。リファラ登録が確認できたら
# "1" にしてアフィリエイト（収益）リンクを有効化する。既定（空/0）は affiliate 無しで安定動作。
RAKUTEN_GORA_USE_AFFILIATE=

# --- 定期バッチ（web が cron ルートをホスト。cron から CRON_SECRET 付きで叩く）---
# /api/cron/sync-races        … マラソン大会フィード取り込み
# /api/cron/sync-osm-facilities … OSM(Overpass) からランニング/公園系施設を取り込み
CRON_SECRET=
# マラソン大会フィード（公式API/許諾フィード）。未設定なら sync-races は無効。
RACE_FEED_URL=
RACE_FEED_KEY=
RACE_FEED_SOURCE=feed
# OSM/Overpass 取り込み。area は都道府県名（prefecture ラベル＋bbox 解決に使用）。
# bbox クエリのため area DB は不要。既定は OSM France 公式（到達性良好）。
# overpass-api.de は area DB を持つが Hetzner 宛 egress が不安定な環境では timeout する。
# LIMIT は1回の処理上限。User-Agent は OSM 利用ポリシー上必須（無いと 406/429）。
# OSM_FETCH_BBOX(south,west,north,east) を設定すると area マップより優先。
OSM_OVERPASS_URL=https://overpass.openstreetmap.fr/api/interpreter
OSM_FETCH_AREA=東京都
OSM_FETCH_LIMIT=300
OSM_USER_AGENT=Spotomo/1.0 (+https://spotomo.lykuro.ai)
# OSM_FETCH_BBOX=35.50,138.94,35.90,139.92
# scheduler が毎週順に取り込む対象（カンマ区切り都道府県名。PREFECTURE_BBOX に存在するもの）。
OSM_FETCH_AREAS=東京都,神奈川県,埼玉県,千葉県,大阪府,愛知県,京都府,兵庫県,福岡県
# 自治体オープンデータ(CKAN/CSV)取り込みの1回あたり処理上限。
MUNICIPAL_FETCH_LIMIT=500
# 自治体CSVの取り込みは出所ごとにライセンス・列が異なるため URL 単位で叩く:
#   GET /api/cron/sync-municipal-facilities?url=<csv>&source=<出所名>&pref=<都道府県>&license=<ライセンス>
# 例: 堺市 スポーツ施設一覧（BODIK CKAN）。CRON_SECRET 付きで呼ぶ。
