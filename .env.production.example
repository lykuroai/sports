# docker compose 用の本番環境変数。`.env.production` にコピーして設定。
# web(統合サイト) と admin コンテナへ env_file で渡す（各 app は必要な変数だけ参照）。

# --- Supabase（ホスティング or セルフホスト）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバー専用。web(統合サイト・取り込みバッチ含む) / admin が利用
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- ドメイン ---
# 統合サイト化により web のログインは web 自身（spotomo）で完結する。
# ACCOUNT_URL/FACILITY_URL は **web のオリジン（=SITE_URL）** を設定する。空でも web 内ログインは
# 動くが、admin(admin-spotomo) からログイン後に admin へ戻す（resolvePostLogin の同一 apex 許可）には
# ACCOUNT_URL を spotomo.lykuro.ai にしておく必要がある。
# COOKIE_DOMAIN=.lykuro.ai は必須: admin は web と別サブドメインで Supabase セッション Cookie を
# 共有するため（外すと admin がログインを認識できずループする）。
NEXT_PUBLIC_SITE_URL=https://spotomo.lykuro.ai
NEXT_PUBLIC_ACCOUNT_URL=https://spotomo.lykuro.ai
NEXT_PUBLIC_FACILITY_URL=https://spotomo.lykuro.ai
NEXT_PUBLIC_COOKIE_DOMAIN=.lykuro.ai

# --- メール通知（Amazon SES）---
# AWS 認証情報（SES 送信権限）。EC2 ならインスタンスロールでも可（その場合キーは空でよい）。
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAIL_PROVIDER=ses
FROM_ADDRESS=no-reply@lykuro.ai
FROM_NAME=SpoTom

# --- 携帯番号認証（Twilio Verify, web の電話OTP）---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- CAPTCHA（Cloudflare Turnstile, web の認証画面）---
# Cloudflare ダッシュボードで Turnstile ウィジェットを作成して取得。
# SITE_KEY はクライアント公開、SECRET_KEY はサーバー検証用（漏らさない）。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Stripe（web のプレミアム会員サブスク）---
# Webhook の宛先は https://spotomo.lykuro.ai/api/stripe/webhook（Stripe ダッシュボードで設定）。
STRIPE_SECRET_KEY=rk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- LINE ログイン（web）---
# LINE Developers のコールバックURLは https://spotomo.lykuro.ai/auth/line/callback。
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- 定期バッチ（web が cron ルートをホスト。cron から CRON_SECRET 付きで叩く）---
# /api/cron/sync-races        … マラソン大会フィード取り込み
# /api/cron/sync-osm-facilities … OSM(Overpass) からランニング/公園系施設を取り込み
CRON_SECRET=
# マラソン大会フィード（公式API/許諾フィード）。未設定なら sync-races は無効。
RACE_FEED_URL=
RACE_FEED_KEY=
RACE_FEED_SOURCE=feed
# OSM/Overpass 取り込み。area は都道府県名（prefecture ラベル＋bbox 解決に使用）。
# bbox クエリのため area DB は不要。既定は OSM France 公式（到達性良好）。
# overpass-api.de は area DB を持つが Hetzner 宛 egress が不安定な環境では timeout する。
# LIMIT は1回の処理上限。User-Agent は OSM 利用ポリシー上必須（無いと 406/429）。
# OSM_FETCH_BBOX(south,west,north,east) を設定すると area マップより優先。
OSM_OVERPASS_URL=https://overpass.openstreetmap.fr/api/interpreter
OSM_FETCH_AREA=東京都
OSM_FETCH_LIMIT=300
OSM_USER_AGENT=Spotomo/1.0 (+https://spotomo.lykuro.ai)
# OSM_FETCH_BBOX=35.50,138.94,35.90,139.92
# scheduler が毎週順に取り込む対象（カンマ区切り都道府県名。PREFECTURE_BBOX に存在するもの）。
OSM_FETCH_AREAS=北海道,青森県,岩手県,宮城県,秋田県,山形県,福島県,茨城県,栃木県,群馬県,埼玉県,千葉県,東京都,神奈川県,新潟県,富山県,石川県,福井県,山梨県,長野県,岐阜県,静岡県,愛知県,三重県,滋賀県,京都府,大阪府,兵庫県,奈良県,和歌山県,鳥取県,島根県,岡山県,広島県,山口県,徳島県,香川県,愛媛県,高知県,福岡県,佐賀県,長崎県,熊本県,大分県,宮崎県,鹿児島県,沖縄県
# 自治体オープンデータ(CKAN/CSV)取り込みの1回あたり処理上限。
MUNICIPAL_FETCH_LIMIT=500
# 自治体CSVの取り込みは出所ごとにライセンス・列が異なるため URL 単位で叩く:
#   GET /api/cron/sync-municipal-facilities?url=<csv>&source=<出所名>&pref=<都道府県>&license=<ライセンス>
# 例: 堺市 スポーツ施設一覧（BODIK CKAN）。CRON_SECRET 付きで呼ぶ。
