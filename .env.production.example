# docker compose 用の本番環境変数。`.env.production` にコピーして設定。
# 全 app コンテナへ env_file で渡す（各 app は必要な変数だけ参照）。

# --- Supabase（ホスティング or セルフホスト）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# サーバー専用。account/golf/running/outdoor/facility/admin が利用（web は未使用）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- ドメイン / SSO ---
NEXT_PUBLIC_ACCOUNT_URL=https://account.spotomo-park.jp
NEXT_PUBLIC_FACILITY_URL=https://facility.spotomo-park.jp
# サブドメイン間で session Cookie を共有（共通 user_id の SSO）
NEXT_PUBLIC_COOKIE_DOMAIN=.spotomo-park.jp

# --- メール通知（任意）---
RESEND_API_KEY=
EMAIL_FROM=no-reply@spotomo-park.jp

# --- Stripe（facility のみ）---
STRIPE_SECRET_KEY=rk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- LINE ログイン（account のみ）---
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
