# Supabase プロジェクト設定（Project Settings > API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー専用。管理タスク／CSV取り込み／通知作成等で使用。クライアントに公開しないこと。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# メール通知（任意）。未設定の場合はメール送信をスキップしログ出力のみ。
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com

# OAuth コールバック等で使用するサイトURL（本番は本番URLを設定）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 共通ユーザ管理(account)のベースURL。種目 app からのログイン誘導・プロフィール導線に使う。
# 本番は https://account.spotomo-park.jp 。未設定（単一オリジン開発）なら各 app の /login に倒れる。
NEXT_PUBLIC_ACCOUNT_URL=http://localhost:3001

# サブドメイン間でセッション Cookie を共有するためのドメイン（本番のみ設定）。
# 例: .spotomo-park.jp 。未設定なら host-only Cookie（ローカル開発はこのまま）。
# NEXT_PUBLIC_COOKIE_DOMAIN=.spotomo-park.jp

# ★Supabase の Exposed schemas（Settings > API）に account, core, facility, golf,
#   running, outdoor を追加すること。スキーマ分離構成で supabase-js が .schema() 経由で
#   これらを参照するため（migrations 0009 で usage を grant 済み）。

# Stripe（収益化 Phase A: 施設運営者プラン）。サーバー専用、クライアントに公開しない。
# STRIPE_SECRET_KEY は制限付き API キー（rk_...）を最小権限で発行することを推奨。
STRIPE_SECRET_KEY=rk_test_xxx
# Webhook 署名シークレット（`stripe listen` または Dashboard の Webhook 設定から取得）
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 施設運営者 app のベースURL（Stripe Checkout/Portal の戻り先）
NEXT_PUBLIC_FACILITY_URL=http://localhost:3005

# LINE ログイン（LINE Developers の Channel）。サーバー専用。
# Callback URL に <ACCOUNT_URL>/auth/line/callback を登録すること。
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
